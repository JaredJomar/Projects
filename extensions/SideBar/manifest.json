{
  "manifest_version": 3,
  "name": "Rail",
  "version": "0.0.1",
  "description": "An MV3 side panel rail for opening user-managed websites.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["sidePanel", "storage", "tabs"],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Open Rail",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "src/panel.html"
  },
  "commands": {
    "return-to-rail": {
      "suggested_key": {
        "default": "Ctrl+B"
      },
      "description": "Open Rail"
    }
  }
}
